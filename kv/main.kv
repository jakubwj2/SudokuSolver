#: import FallOutTransition kivy.uix.screenmanager.FallOutTransition
#: import RiseInTransition kivy.uix.screenmanager.RiseInTransition

#:set primary_color rgba("#1a5653")
#:set secondary_color rgba("#08313a")
#:set bg_primary_color rgba("#5cd85a")
#:set bg_secondary_color rgba("#107869")
#:set bg_tetriary_color rgba("#74ff72")
#:set spacing_padding dp(20)
#:set font_s sp(25)
#:set border_size dp(3)
#:set transition_len .25

<RootLayout>:
    Label:
        text: "v" + app.app_version
        size_hint: None, None
        size: self.texture_size
        font_size: font_s // 2
        color: 0, 0, 0, 0.4
        pos_hint: {"x": 0.01, "y": 0.005}


<CameraScreen>
    name: "camera"
    my_camera: camera
    BoxLayout:
        orientation: "horizontal" if root.width > root.height else "vertical"
        RelativeLayout:
            # Landscape: fixed 16:9 strip full height. Portrait: fill space above capture.
            size_hint_x: None if root.width > root.height else 1
            size_hint_y: 1
            width: self.height * 16 / 9
            CameraPreview:
                id: camera
                canvas.before:
                    PushMatrix
                    Rotate:
                        angle: 180
                        origin: self.center
                canvas.after:
                    PopMatrix
                fit_mode: "fill"

            OperationButton:
                icon_source: "data/icons/pngs/back.png"
                background_color: 0, 0, 0, 0
                image_color: .33, .33, .33, 1
                size_hint: None, None
                size: dp(64), dp(64)
                pos_hint: {"x": 0.02, "top": 0.98}
                canvas.before:
                    Color:
                        rgba: .75, .75, .75, 0.5
                    Ellipse:
                        pos: self.pos
                        size: self.size
                on_press:
                    root.manager.transition = FallOutTransition(duration = transition_len)
                    root.manager.current = "sudoku"

        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"
            # Landscape: fill remaining width. Portrait: fixed bar under the preview.
            size_hint_x: 1
            size_hint_y: 1 if root.width > root.height else None
            height: dp(180)
            OperationButton:
                id: capture_sudoku_button
                icon_source: "data/icons/pngs/capture_sudoku.png"
                background_color: .1, .1, .1, 1
                on_press: root.capture_sudoku()
                disabled: True
                image_color: (0.2, 0.2, 0.2, 1) if self.disabled else (0.9, 0.9, 0.9, 1)



<SudokuScreen>
    name: "sudoku"
    BoxLayout:
        orientation: "vertical"
        padding: spacing_padding
        spacing: spacing_padding
        canvas:
            Color:
                rgba: bg_primary_color
            Rectangle:
                size: root.size
                pos: root.pos

        BoxLayout:
            orientation: "horizontal" if root.width > root.height else "vertical"
            spacing: spacing_padding
            size_hint_y: 1
            AnchorLayout:
                anchor_x: "center"
                anchor_y: "center"
                SudokuWidget:
                    cols: 3
                    spacing: border_size
                    size_hint: None, None
                    size: min(self.parent.height, self.parent.width), min(self.parent.height, self.parent.width)
                    canvas.before:
                        Color:
                            rgba: secondary_color
                        Rectangle:
                            pos: self.x - border_size, self.y - border_size
                            size: self.width + border_size * 2, self.height + border_size * 2

            AnchorLayout:
                anchor_x: "center"
                anchor_y: "center"
                DialWidget:
                    cols: 3
                    spacing: spacing_padding / 2
                    size_hint: None, None
                    size: min(self.parent.height, self.parent.width), min(self.parent.height, self.parent.width)

        BoxLayout:
            orientation: "horizontal"
            spacing: spacing_padding / 2
            size_hint_y: None
            height: dp(72)
            OperationButton:
                icon_source: "data/icons/pngs/clear.png"
                on_press: app.on_clear(self)
            ToggleOperationButton:
                default_icon_source: "data/icons/pngs/lock.png"
                toggled_icon_source: "data/icons/pngs/unlock.png"
                on_press: app.on_lock(self)
            # OperationButton:
            #     text: "Filter"
            #     on_press: app.on_filter(self)
            ToggleOperationButton:
                default_icon_source: "data/icons/pngs/pencil.png"
                toggled_icon_source: "data/icons/pngs/remove_pencil.png"
                on_press: app.on_show_candidates(self)
            ToggleOperationButton:
                id: solve_toggle_button
                default_icon_source: "data/icons/pngs/solve.png"
                toggled_icon_source: "data/icons/pngs/restart.png"
                on_press: app.on_solve(self)
            OperationButton:
                icon_source: "data/icons/pngs/camera.png"
                on_press:
                    root.manager.transition = RiseInTransition(duration = transition_len)
                    root.manager.current = "camera"

<OperationButton>:
    size_hint: 1, 1
    background_normal: ""
    background_down: ""
    background_disabled_normal: ""
    background_disabled_down: ""
    background_color: secondary_color
    color: bg_primary_color
    disabled_color: bg_primary_color
    font_size: font_s
    image_scale: 0.9

    Image:
        source: root.icon_source
        size_hint: None, None
        size: min(self.parent.width, self.parent.height) * root.image_scale, min(self.parent.width, self.parent.height) * root.image_scale
        pos: self.parent.center_x - self.width / 2, self.parent.center_y - self.height / 2
        color: (.45, .45, .45, 1) if root.disabled else (root.image_color if root.image_color else bg_primary_color)
        opacity: 1 if root.icon_source else 0

<ToggleOperationButton>:
    icon_source: self.toggled_icon_source if self.toggled else self.default_icon_source

<SudokuCell>
    anchor_x: "center"
    anchor_x: "center"
    canvas:
        Color: 
            rgba: root.background_color
        Rectangle:
            pos:self.pos
            size:self.size
    canvas.before:
        Color:
            rgba: bg_tetriary_color
        Rectangle:
            pos: self.pos
            size: self.size
    Label:
        text: str(root.number if root.number != 0 else "")
        color: root.text_color
        font_size: font_s

    Label:
        text: root.candidate_list
        font_size:sp(11)
        color: "black"


<DialButton>
    text: str(self.number)
    background_normal: ""
    background_color: bg_tetriary_color
    color: secondary_color
    font_size: font_s * 1.5
    group:"dial_buttons"


<-ConfirmPopup>:
	GridLayout:
		cols: 1
		padding: '12dp'
		pos_hint: {'center': (0.5, 0.5)}
		size_hint_x: 0.66
		size_hint_y: None
		height: self.minimum_height

		canvas:
			Color:
				rgba: root.background_color[:3] + [root.background_color[-1] * root._anim_alpha]
			Rectangle:
				size: root._window.size if root._window else (0, 0)

			Color:
				rgb: 1, 1, 1
			BorderImage:
				source: root.background
				border: root.border
				pos: self.pos
				size: self.size

		Label:
			text: root.text
			size_hint_y: None
			height: self.texture_size[1] + dp(16)
			text_size: self.width - dp(16), None
			halign: 'center'

		BoxLayout:
			size_hint_y: None
			height: sp(48)

			Button:
				text: root.ok_text
				on_press: root.ok()
			Button:
				text: root.cancel_text
				on_press: root.cancel()
